<Window x:Class="WinForge.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="WinForge" Height="820" Width="1200" MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen" Background="#16181D" Icon="app.ico">
    <Grid>
        <wv2:WebView2 x:Name="web"/>
        <TextBlock x:Name="lblBoot" Text="Loading WinForge…" Foreground="#9AA0AA"
                   FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Grid>
</Window>
