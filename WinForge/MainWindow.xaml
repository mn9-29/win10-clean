<Window x:Class="WinForge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinForge"
        Title="WinForge" Height="760" Width="940" Icon="app.ico"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource BgBrush}">

    <Window.Resources>
        <!-- Theme brushes (swapped at runtime by the theme toggle) -->
        <SolidColorBrush x:Key="BgBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#252526"/>
        <SolidColorBrush x:Key="FgBrush" Color="#EEEEEE"/>
        <SolidColorBrush x:Key="FgDimBrush" Color="#999999"/>
        <SolidColorBrush x:Key="SepBrush" Color="#33FFFFFF"/>

        <!-- Template for one checkbox + description -->
        <DataTemplate x:Key="TweakTemplate" DataType="{x:Type local:TweakItem}">
            <Border BorderBrush="{DynamicResource SepBrush}" BorderThickness="0,0,0,1" Padding="8,6">
                <StackPanel>
                    <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding Title}"
                              Foreground="{DynamicResource FgBrush}" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource FgDimBrush}"
                               Margin="22,2,0,0" TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <Style x:Key="Pill" TargetType="Button">
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Dashboard row label -->
        <Style x:Key="DbKey" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgDimBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
        </Style>
        <Style x:Key="DbVal" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource FgBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Margin" Value="0,5,0,5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="WinForge" Foreground="#4EC9B0" FontSize="24" FontWeight="Bold"/>
                <TextBlock x:Name="lblVersion" Text="v2.11.2" Foreground="{DynamicResource FgDimBrush}" FontSize="14"
                           VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                <TextBlock x:Name="lblSubtitle" Text="  -  tick what you want, then Apply" Foreground="{DynamicResource FgDimBrush}"
                           FontSize="13" VerticalAlignment="Bottom" Margin="6,0,0,4"/>
            </StackPanel>
            <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="{DynamicResource PanelBrush}" CornerRadius="4" Padding="12,6">
                <TextBlock x:Name="lblRam" Text="RAM: -" FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                           Foreground="#DDDDDD"/>
            </Border>
            <!-- Update notice bar (hidden until a newer release is found) -->
            <Border x:Name="barUpdate" Grid.Row="1" Margin="0,10,0,0" Background="#173A1F" BorderBrush="#0E7C3A"
                    BorderThickness="1" CornerRadius="6" Padding="12,8" Visibility="Collapsed">
                <DockPanel LastChildFill="True">
                    <Button x:Name="btnUpdateLater" DockPanel.Dock="Right" Content="Dismiss" Style="{StaticResource Pill}"
                            Background="#2A2A2A" Click="btnUpdateLater_Click"/>
                    <Button x:Name="btnUpdateGet" DockPanel.Dock="Right" Content="Download" Style="{StaticResource Pill}"
                            Background="#0E7C3A" Click="btnUpdateGet_Click"/>
                    <TextBlock x:Name="lblUpdate" VerticalAlignment="Center" Foreground="#CFFFD9"
                               FontWeight="SemiBold" Text="A new version is available."/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Presets row -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock x:Name="lblPreset" Text="Preset:" Foreground="{DynamicResource FgBrush}" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold"/>
            <Button x:Name="btnWork"   Content="Office / Work" Style="{StaticResource Pill}" Click="btnWork_Click"/>
            <Button x:Name="btnGaming" Content="Gaming"        Style="{StaticResource Pill}" Click="btnGaming_Click"/>
            <Button x:Name="btnBasic"  Content="Basic / Home"  Style="{StaticResource Pill}" Click="btnBasic_Click"/>
            <Button x:Name="btnClear"  Content="Clear all"     Style="{StaticResource Pill}" Click="btnClear_Click"/>
            <Button x:Name="btnSave"   Content="Save profile"  Style="{StaticResource Pill}" Background="#2D4A2D" Click="btnSave_Click"/>
            <Button x:Name="btnLoad"   Content="Load profile"  Style="{StaticResource Pill}" Background="#2D4A2D" Click="btnLoad_Click"/>
            <Separator Width="10" Opacity="0"/>
            <CheckBox x:Name="cbRestore" Content="Create restore point first (recommended)"
                      IsChecked="True" Foreground="{DynamicResource FgBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
            <CheckBox x:Name="cbBackupReg" Content="Backup registry too" Margin="12,0,0,0"
                      Foreground="{DynamicResource FgBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </WrapPanel>

        <!-- Search / select-all / sizes / theme toolbar -->
        <DockPanel Grid.Row="2" Margin="0,0,0,8" LastChildFill="True">
            <Button x:Name="btnAbout"   DockPanel.Dock="Right" Content="About" Style="{StaticResource Pill}" Background="#2A2A2A" Click="btnAbout_Click"/>
            <Button x:Name="btnTheme"   DockPanel.Dock="Right" Content="Light theme" Style="{StaticResource Pill}" Click="btnTheme_Click"/>
            <Button x:Name="btnLang"    DockPanel.Dock="Right" Content="العربية" Style="{StaticResource Pill}" Background="#3A2A50" Click="btnLang_Click"/>
            <Button x:Name="btnUpdates" DockPanel.Dock="Right" Content="Check updates" Style="{StaticResource Pill}" Background="#2A3A50" Click="btnUpdates_Click"/>
            <Button x:Name="btnSelAll"  DockPanel.Dock="Left"  Content="Select all (tab)" Style="{StaticResource Pill}" Click="btnSelAll_Click"/>
            <Button x:Name="btnSelNone" DockPanel.Dock="Left"  Content="None (tab)" Style="{StaticResource Pill}" Click="btnSelNone_Click"/>
            <Button x:Name="btnSizes"   DockPanel.Dock="Left"  Content="App sizes" Style="{StaticResource Pill}" Background="#3A3050" Click="btnSizes_Click"/>
            <TextBox x:Name="txtSearch" Margin="4,0,8,0" VerticalContentAlignment="Center" Padding="6,4"
                     Background="{DynamicResource PanelBrush}" Foreground="{DynamicResource FgBrush}"
                     BorderBrush="#555" TextChanged="txtSearch_TextChanged" ToolTip="Filter items by name..."/>
        </DockPanel>

        <!-- Tabs -->
        <TabControl x:Name="tabs" Grid.Row="3" Background="{DynamicResource PanelBrush}" BorderBrush="#444">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">
                        <TextBlock Text="System overview" Foreground="#4EC9B0" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>
                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="#444" BorderThickness="1" CornerRadius="8" Padding="18,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Windows"  Style="{StaticResource DbKey}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="dbOs"     Text="-" Style="{StaticResource DbVal}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Computer"  Style="{StaticResource DbKey}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="dbHost"   Text="-" Style="{StaticResource DbVal}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Processor" Style="{StaticResource DbKey}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="dbCpu"    Text="-" Style="{StaticResource DbVal}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="CPU load"  Style="{StaticResource DbKey}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="dbCpuUse" Text="-" Style="{StaticResource DbVal}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Memory"    Style="{StaticResource DbKey}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="dbRam"    Text="-" Style="{StaticResource DbVal}"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="Graphics"  Style="{StaticResource DbKey}"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="dbGpu"    Text="-" Style="{StaticResource DbVal}"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Disk C:"   Style="{StaticResource DbKey}"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="dbDisk"   Text="-" Style="{StaticResource DbVal}"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Uptime"    Style="{StaticResource DbKey}"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="dbUptime" Text="-" Style="{StaticResource DbVal}"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="WinForge status" Foreground="#4EC9B0" FontSize="15" FontWeight="Bold" Margin="2,18,0,8"/>
                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="#444" BorderThickness="1" CornerRadius="8" Padding="18,12">
                            <TextBlock x:Name="dbFlags" Text="-" Foreground="{DynamicResource FgBrush}" FontFamily="Consolas"
                                       FontSize="13" TextWrapping="Wrap" LineHeight="22"/>
                        </Border>
                        <Button x:Name="btnDbRefresh" Content="Refresh" Style="{StaticResource Pill}" HorizontalAlignment="Left"
                                Margin="0,12,0,0" Background="#2A3A50" Click="btnDbRefresh_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Device Modes">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="8">
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource FgDimBrush}" Margin="4,4,4,12"
                                   Text="One click switches your whole device for the task at hand. Fully reversible - just activate another mode whenever you change what you're doing."/>

                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="#0E7C3A" BorderThickness="2"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <StackPanel HorizontalAlignment="Left" MaxWidth="640">
                                    <TextBlock Text="GAMING MODE" Foreground="#4EC9B0" FontSize="19" FontWeight="Bold"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource FgBrush}" Margin="0,6,0,0"
                                               Text="High Performance power plan, Game Mode ON, and shuts down Docker + WSL and closes dev tools to free RAM/CPU - only gaming stuff stays."/>
                                </StackPanel>
                                <Button x:Name="btnModeGaming" Content="ACTIVATE" Click="btnModeGaming_Click"
                                        Style="{StaticResource Pill}" Background="#0E7C3A" Padding="28,12" FontSize="15"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="#2D6CDF" BorderThickness="2"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <StackPanel HorizontalAlignment="Left" MaxWidth="640">
                                    <TextBlock Text="PROGRAMMING MODE" Foreground="#6CA8FF" FontSize="19" FontWeight="Bold"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource FgBrush}" Margin="0,6,0,0"
                                               Text="High Performance power plan, closes gaming apps (Steam/Discord/Epic), and starts Docker Desktop + WSL ready for development."/>
                                </StackPanel>
                                <Button x:Name="btnModeDev" Content="ACTIVATE" Click="btnModeDev_Click"
                                        Style="{StaticResource Pill}" Background="#2D6CDF" Padding="28,12" FontSize="15"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="#B58A2E" BorderThickness="2"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <StackPanel HorizontalAlignment="Left" MaxWidth="640">
                                    <TextBlock Text="OFFICE MODE" Foreground="#E5B84B" FontSize="19" FontWeight="Bold"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource FgBrush}" Margin="0,6,0,0"
                                               Text="Balanced power plan, closes both gaming apps and Docker/WSL to keep the device light and quiet for office work."/>
                                </StackPanel>
                                <Button x:Name="btnModeOffice" Content="ACTIVATE" Click="btnModeOffice_Click"
                                        Style="{StaticResource Pill}" Background="#B58A2E" Padding="28,12" FontSize="15"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource FgDimBrush}" Margin="4,2,4,4" FontSize="11"
                                   Text="Note: modes start/stop apps and services and set the power plan - they do NOT delete anything. Unsaved work in apps that get closed may be lost, so save first."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Apps / Games">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icApps" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Installed (scan)">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="#444" BorderThickness="0,0,0,1" Padding="8,8">
                            <DockPanel LastChildFill="True">
                                <Button x:Name="btnScan" DockPanel.Dock="Right" Content="Scan this PC" Style="{StaticResource Pill}"
                                        Background="#3A3050" Click="btnScan_Click"/>
                                <TextBlock x:Name="lblScan" VerticalAlignment="Center" TextWrapping="Wrap"
                                           Foreground="{DynamicResource FgDimBrush}" FontSize="12"
                                           Text="Scans every removable Appx package actually installed on THIS PC (with sizes). Tick the ones you want gone, then Apply."/>
                            </DockPanel>
                        </Border>
                        <ItemsControl x:Name="icScan" ItemTemplate="{StaticResource TweakTemplate}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Privacy / Ads">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icPrivacy" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Services">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icServices" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Gaming">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icGaming" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Performance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icPerf" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Network">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icNetwork" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Updates">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icUpdates" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Win 11 / UI">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icUi" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Maintenance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{DynamicResource PanelBrush}" BorderBrush="#444" BorderThickness="0,0,0,1" Padding="8,8">
                            <DockPanel LastChildFill="True">
                                <Button x:Name="btnRestoreReg" DockPanel.Dock="Right" Content="Restore .reg" Style="{StaticResource Pill}"
                                        Background="#5A3A1A" Click="btnRestoreReg_Click"/>
                                <Button x:Name="btnBackupReg" DockPanel.Dock="Right" Content="Backup registry now" Style="{StaticResource Pill}"
                                        Background="#2D4A2D" Click="btnBackupReg_Click"/>
                                <TextBlock x:Name="lblMaint" VerticalAlignment="Center" TextWrapping="Wrap"
                                           Foreground="{DynamicResource FgDimBrush}" FontSize="12"
                                           Text="Health &amp; repair tools. SFC and DISM can take 10-20 minutes - leave them running. Tick what you need, then Apply."/>
                            </DockPanel>
                        </Border>
                        <ItemsControl x:Name="icMaint" ItemTemplate="{StaticResource TweakTemplate}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Cleanup">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icCleanup" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="WSL / Startup">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icSystem" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="Install (winget)">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icInstall" ItemTemplate="{StaticResource TweakTemplate}"/>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Log -->
        <TextBox x:Name="txtLog" Grid.Row="4" Margin="0,10,0,10"
                 Background="#0C0C0C" Foreground="#33FF66" FontFamily="Consolas" FontSize="12"
                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"
                 BorderBrush="#444" BorderThickness="1"/>

        <!-- Bottom bar -->
        <Grid Grid.Row="5">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <ProgressBar x:Name="prog" Width="180" Height="10" IsIndeterminate="False"
                             Visibility="Collapsed" VerticalAlignment="Center"/>
                <TextBlock x:Name="lblStatus" Text="Ready" Foreground="{DynamicResource FgDimBrush}"
                           VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnDocker" Content="Docker Prune" Style="{StaticResource Pill}"
                        Background="#1A4A55" Click="btnDocker_Click"/>
                <Button x:Name="btnExplorer" Content="Restart Explorer" Style="{StaticResource Pill}"
                        Background="#3A3A55" Click="btnExplorer_Click"/>
                <Button x:Name="btnRevert" Content="Revert settings (Undo)" Style="{StaticResource Pill}"
                        Background="#5A3A1A" Click="btnRevert_Click"/>
                <Button x:Name="btnApply" Content="APPLY SELECTED" Style="{StaticResource Pill}"
                        Background="#0E7C3A" Padding="22,8" FontSize="14" Click="btnApply_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
